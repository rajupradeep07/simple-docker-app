pipeline {
    agent any

    stages {
        stage('Fix Docker Compose') {
            steps {
                dir('messagefetcher-app') {
                    script {
                        // Check if 'docker compose' works. If not, download the standalone binary.
                        def composeExists = sh(script: "docker compose version", returnStatus: true) == 0
                        if (!composeExists) {
                            echo "Docker Compose plugin not found. Downloading standalone binary..."
                            sh '''
                                curl -SL https://github.com/docker/compose/releases/download/v2.26.1/docker-compose-linux-x86_64 -o ./docker-compose
                                chmod +x ./docker-compose
                            '''
                            env.DOCKER_COMPOSE_CMD = "./docker-compose"
                        } else {
                            env.DOCKER_COMPOSE_CMD = "docker compose"
                        }
                    }
                }
            }
        }

        stage('Clean and Deploy') {
            steps {
                dir('messagefetcher-app') {
                    echo "Using command: ${env.DOCKER_COMPOSE_CMD}"
                    
                    // Cleanup old containers
                    sh "${env.DOCKER_COMPOSE_CMD} down --remove-orphans"
                    
                    // Build and start
                    sh "${env.DOCKER_COMPOSE_CMD} up -d --build"
                    
                    echo "Waiting for services to wake up..."
                    sleep 10
                }
            }
        }

        stage('Verify Communication') {
            steps {
                echo "Final Test: Fetching data from Frontend..."
                sh 'curl -s http://localhost:7777'
            }
        }
    }
}
