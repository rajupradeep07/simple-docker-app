pipeline {
    agent any

    stages {
        stage('Deploy App') {
            steps {
                // Step into the subfolder before running Docker commands
                dir('messagefetcher-app') {
                    // Pre-cleanup to ensure no old containers are blocking ports
                    sh 'docker-compose down --remove-orphans'
                    
                    // Build and start
                    sh 'docker-compose up -d --build'
                    
                    echo "Waiting for containers..."
                    sleep 5
                    
                    // Verify the output
                    sh 'curl -s http://localhost:7777'
                }
            }
        }
    }
}
